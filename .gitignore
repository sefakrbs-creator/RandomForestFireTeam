# Project specific ignores
# Block large data folders by default
Independence_Lake/
Pacific_Union/
predictions_v12/
Sedgwick/
Shaver_Lake/
DL_Bliss/
Calaveras_Big_trees/

# But allow code and images inside them if they exist
!**/
!*.py
!*.ipynb
!*.json
!*.md
!*.png
!*.jpg
!*.jpeg

# Explicitly block large binary data everywhere
*.tif
*.tiff
*.laz
*.ptx
*.joblib
*.docx
*.pdf
*.pth
*.npy
*.zip
*.tar.gz

# Block specific giant files across all sites
*predicted_shrub_v*.geojson
*merged_grid_stats.geojson
*merged_grid_stats.csv
*predicted_grid_stats.geojson
mask_outputs/
mask_outputs_sprint4/
mask_outputs_test_6350/
data_challenge/
DEM/
burn_units/
NAIP_3DEP_product/

# Exceptions for specific folders
!predictions_v12/**/*.tif
!predictions_v12/**/*.tiff

# Block specific junk folders
__pycache__/
venv/
venv_linux/
.claude/
.ipynb_checkpoints/
node_modules/
